<%- include('partials/header') %>

<div class="not-found">
  <div class="nf-emoji">🔍</div>
  <h1>页面未找到</h1>
  <p>抱歉，您访问的页面不存在。</p>
  <a href="/" class="nf-back-btn">← 返回首页</a>
  <% if (games && games.length > 0) { %>
  <div class="nf-games">
    <h3>您可以试试这些游戏：</h3>
    <div class="game-grid">
      <% games.slice(0, 4).forEach(function(game) { %>
      <a href="/game/<%= game.id %>" class="game-card"
         style="--thumb-bg: <%= game.thumbnailBg %>">
        <div class="card-thumb">
          <span class="card-emoji"><%= game.thumbnailIcon %></span>
        </div>
        <div class="card-body">
          <h3 class="card-title"><%= game.title %></h3>
          <div class="card-meta">
            <span class="card-category"><%= game.categoryName %></span>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
